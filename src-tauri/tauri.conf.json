{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TFT Companion Overlay",
  "version": "0.1.0",
  "identifier": "com.guilhermecosta.tft-overlay",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "dashboard",
        "title": "TFT Companion Overlay",
        "width": 1024,
        "height": 720,
        "resizable": true,
        "center": true
      },
      {
        "label": "overlay",
        "title": "TFT Overlay",
        "url": "/overlay",
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true,
        "visible": false,
        "width": 360,
        "height": 600,
        "x": 10,
        "y": 100
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' https://ddragon.leagueoflegends.com data:; style-src 'self' 'unsafe-inline'; connect-src 'self' https://127.0.0.1:* https://*.api.riotgames.com https://ddragon.leagueoflegends.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0"
    }
  }
}
